# Resend API key — from resend.com dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address — must be from a verified domain in your Resend account
# e.g. noreply@yourdomain.com
# Omit this var to fall back to onboarding@resend.dev (only works to your own email)
RESEND_FROM=Portfolio Contact <noreply@yourdomain.com>

# Where to deliver contact form messages
CONTACT_RECIPIENT=your-email@gmail.com
